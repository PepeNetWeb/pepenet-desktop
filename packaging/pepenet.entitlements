<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- The wallet/signing key lives in the Keychain (see platform_secret_* /
       wallet.c). This access group lets a signed app add + read its own item
       without the per-launch authorization prompt an unsigned build hits.
       With a real Developer ID the group is prefixed by the team id at build
       time; ad-hoc builds fall back to a prompt on first access. -->
  <key>keychain-access-groups</key>
  <array>
    <string>$(AppIdentifierPrefix)com.pepenet.app</string>
  </array>
</dict>
</plist>
